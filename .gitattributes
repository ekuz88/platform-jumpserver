###############################################################################
# Default rule — normalize all text files to LF
###############################################################################

* text=auto eol=lf


###############################################################################
# 📏 Line Ending Exceptions (Windows scripts)
###############################################################################

*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf


###############################################################################
# 💬 Common Text-Based Source Files
###############################################################################

*.sh     text eol=lf
*.bash   text eol=lf
*.zsh    text eol=lf
*.py     text eol=lf
*.yaml   text eol=lf diff=yaml
*.yml    text eol=lf diff=yaml
*.json   text eol=lf
*.md     text eol=lf
*.sql    text eol=lf
*.env    text eol=lf
*.ini    text eol=lf
*.conf   text eol=lf
*.tf     text eol=lf diff=terraform
*.tfvars text eol=lf diff=terraform

Makefile text eol=lf
Dockerfile text eol=lf


###############################################################################
# 🧱 Git LFS — Large Binary Files
###############################################################################
# Use LFS only for large artifacts that must exist in the repository.
###############################################################################

*.tar     filter=lfs diff=lfs merge=lfs -text
*.tar.gz  filter=lfs diff=lfs merge=lfs -text
*.tgz     filter=lfs diff=lfs merge=lfs -text
*.zip     filter=lfs diff=lfs merge=lfs -text
*.7z      filter=lfs diff=lfs merge=lfs -text

*.iso     filter=lfs diff=lfs merge=lfs -text
*.img     filter=lfs diff=lfs merge=lfs -text
*.qcow2   filter=lfs diff=lfs merge=lfs -text
*.vmdk    filter=lfs diff=lfs merge=lfs -text
*.ova     filter=lfs diff=lfs merge=lfs -text

*.bin     filter=lfs diff=lfs merge=lfs -text


###############################################################################
# 📸 Media and Documentation Assets
###############################################################################

*.png  filter=lfs diff=lfs merge=lfs -text
*.jpg  filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif  filter=lfs diff=lfs merge=lfs -text

*.pdf  filter=lfs diff=lfs merge=lfs -text


###############################################################################
# 📦 Package Artifacts (only if intentionally stored)
###############################################################################

*.whl filter=lfs diff=lfs merge=lfs -text
*.pex filter=lfs diff=lfs merge=lfs -text


###############################################################################
# 🛠 Local helper binaries
###############################################################################

utils/* filter=lfs diff=lfs merge=lfs -text


###############################################################################
# 🔒 Security Reminder
###############################################################################
# Git LFS is NOT a secret store.
# Never commit credentials, private keys, certificates, or kubeconfigs.
# Use Vault, SOPS, or Ansible Vault for secrets.
###############################################################################
