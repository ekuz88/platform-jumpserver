###############################################################################
# 🌍 Example Terraform variables
###############################################################################
# Copy this file to:
#
#   terraform.tfvars
#
# and fill in real values locally. The terraform.tfvars file should NOT be
# committed to Git because it may contain secrets.
###############################################################################

###############################################################################
# oVirt API endpoint
###############################################################################
api_url = "https://**.**/ovirt-engine/api"

###############################################################################
# Service account used by Terraform
###############################################################################
username = "**@internalsso"

###############################################################################
# Replace with the real password for the service account
###############################################################################
password = "CHANGE_ME"

###############################################################################
# Skip TLS verification (useful for lab/self-signed environments)
###############################################################################
insecure = true

###############################################################################
# Target cluster ID from zVirt / oVirt
###############################################################################
cluster_id = "PUT_REAL_CLUSTER_ID_HERE"